// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String
  roleId        String
  role          Role      @relation(fields: [roleId], references: [id])
  employee      Employee?
  sessions      Session[]
  activityLogs  ActivityLog[]
  notifications Notification[]
  orderStatusHistories OrderStatusHistory[]
  inventoryTransactions InventoryTransaction[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([roleId])
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique // Owner, Manager, Cashier, Waiter, Kitchen, Bar, Accountant
  permissions Permission[]
  users       User[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Permission {
  id        String   @id @default(cuid())
  name      String   @unique // e.g. "orders:create", "inventory:manage"
  roles     Role[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Employee {
  id               String       @id @default(cuid())
  userId           String       @unique
  user             User         @relation(fields: [userId], references: [id])
  position         String
  hourlyRate       Float
  hireDate         DateTime     @default(now())
  attendance       Attendance[]
  shifts           Shift[]
  managedOrders    Order[]      @relation("WaiterOrders")
  kitchenOrders    Order[]      @relation("KitchenStaff")
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model Attendance {
  id          String   @id @default(cuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
  clockIn     DateTime @default(now())
  clockOut    DateTime?
  totalHours  Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([employeeId])
}

model Shift {
  id          String   @id @default(cuid())
  employeeId  String
  employee    Employee @relation(fields: [employeeId], references: [id])
  startTime   DateTime
  endTime     DateTime
  status      String   // Scheduled, Completed, Cancelled
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([employeeId])
}

model Table {
  id           String        @id @default(cuid())
  number       String        @unique
  capacity     Int
  status       String        @default("Available") // Available, Occupied, Reserved, Cleaning
  reservations Reservation[]
  orders       Order[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Reservation {
  id          String   @id @default(cuid())
  tableId     String
  table       Table    @relation(fields: [tableId], references: [id])
  customerName String
  customerPhone String
  startTime   DateTime
  endTime     DateTime?
  status      String   // Pending, Confirmed, Completed, Cancelled
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tableId])
}

model Order {
  id              String      @id @default(cuid())
  tableId         String?
  table           Table?      @relation(fields: [tableId], references: [id])
  waiterId        String?
  waiter          Employee?   @relation("WaiterOrders", fields: [waiterId], references: [id])
  kitchenStaffId  String?
  kitchenStaff    Employee?   @relation("KitchenStaff", fields: [kitchenStaffId], references: [id])
  status          String      @default("DRAFT") // DRAFT, CONFIRMED, PREPARING, READY, SERVED, PAID, CLOSED, CANCELLED
  type            String      @default("DineIn") // DineIn, Takeaway, Delivery
  notes           String?
  subtotal        Float
  taxAmount       Float
  discountAmount  Float       @default(0)
  total           Float
  items           OrderItem[]
  payments        Payment[]
  couponId        String?
  coupon          Coupon?     @relation(fields: [couponId], references: [id])
  cashierSessionId String?
  cashierSession  CashierSession? @relation(fields: [cashierSessionId], references: [id])
  statusHistory   OrderStatusHistory[]
  confirmedAt     DateTime?
  preparingAt     DateTime?
  readyAt         DateTime?
  servedAt        DateTime?
  paidAt          DateTime?
  closedAt        DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([tableId])
  @@index([waiterId])
  @@index([kitchenStaffId])
  @@index([couponId])
  @@index([cashierSessionId])
}

model OrderItem {
  id              String         @id @default(cuid())
  orderId         String
  order           Order          @relation(fields: [orderId], references: [id])
  productId       String
  product         Product        @relation(fields: [productId], references: [id])
  productVariantId String?
  productVariant  ProductVariant? @relation(fields: [productVariantId], references: [id])
  modifiers       OrderItemModifier[]
  quantity        Int
  unitPrice       Float
  totalPrice      Float
  notes           String?
  status          String         @default("Pending") // Pending, Preparing, Ready, Served
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([orderId])
  @@index([productId])
  @@index([productVariantId])
}

model OrderItemModifier {
  id          String    @id @default(cuid())
  orderItemId String
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  modifierId  String
  modifier    Modifier  @relation(fields: [modifierId], references: [id])
  quantity    Int       @default(1)
  price       Float     // Price at time of order

  @@index([orderItemId])
  @@index([modifierId])
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  image       String?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Product {
  id          String              @id @default(cuid())
  categoryId  String
  category    Category            @relation(fields: [categoryId], references: [id])
  name        String
  description String?
  price       Float
  costPrice   Float               @default(0)
  image       String?
  isAvailable Boolean             @default(true)
  variants    ProductVariant[]
  modifierGroups ProductModifierGroup[]
  orderItems  OrderItem[]
  recipeItems ProductIngredient[]
  activeRecipeId String?          @unique
  activeRecipe   Recipe?          @relation("ProductActiveRecipe", fields: [activeRecipeId], references: [id])
  recipes        Recipe[]         @relation("ProductRecipes")
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([categoryId])
}

model ProductVariant {
  id          String              @id @default(cuid())
  productId   String
  product     Product             @relation(fields: [productId], references: [id])
  name        String              // Small, Medium, Large, Spicy, etc.
  price       Float
  costPrice   Float               @default(0)
  orderItems  OrderItem[]
  recipeItems ProductIngredient[]
  activeRecipeId String?          @unique
  activeRecipe   Recipe?          @relation("VariantActiveRecipe", fields: [activeRecipeId], references: [id])
  recipes        Recipe[]         @relation("VariantRecipes")
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([productId])
}

model ModifierGroup {
  id          String              @id @default(cuid())
  name        String
  minSelection Int                @default(0)
  maxSelection Int                @default(1)
  modifiers   Modifier[]
  products    ProductModifierGroup[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model ProductModifierGroup {
  productId       String
  product         Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  modifierGroupId String
  modifierGroup   ModifierGroup  @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)
  createdAt       DateTime       @default(now())

  @@id([productId, modifierGroupId])
}

model Modifier {
  id              String              @id @default(cuid())
  modifierGroupId String
  modifierGroup   ModifierGroup       @relation(fields: [modifierGroupId], references: [id], onDelete: Cascade)
  name            String
  price           Float               @default(0)
  costPrice       Float               @default(0)
  isAvailable     Boolean             @default(true)
  activeRecipeId  String?             @unique
  activeRecipe    Recipe?             @relation("ModifierActiveRecipe", fields: [activeRecipeId], references: [id])
  recipes         Recipe[]            @relation("ModifierRecipes")
  orderItemModifiers OrderItemModifier[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([modifierGroupId])
}

model Recipe {
  id               String       @id @default(cuid())
  name             String
  version          Int          @default(1)
  isActive         Boolean      @default(true)
  notes            String?
  preparationSteps RecipeStep[]
  ingredients      RecipeIngredient[]
  
  // Targets
  product          Product?     @relation("ProductRecipes", fields: [productId], references: [id])
  productId        String?
  productVariant   ProductVariant? @relation("VariantRecipes", fields: [productVariantId], references: [id])
  productVariantId String?
  modifier         Modifier?    @relation("ModifierRecipes", fields: [modifierId], references: [id])
  modifierId       String?
  ingredient       Ingredient?  @relation("IngredientRecipe")
  
  // Backlinks for active selection
  activeForProduct Product?     @relation("ProductActiveRecipe")
  activeForVariant ProductVariant? @relation("VariantActiveRecipe")
  activeForModifier Modifier?   @relation("ModifierActiveRecipe")

  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([productId])
  @@index([productVariantId])
  @@index([modifierId])
}

model RecipeIngredient {
  id           String      @id @default(cuid())
  recipeId     String
  recipe       Recipe      @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredientId String
  ingredient   Ingredient  @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  quantity     Float
  unit         String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([recipeId])
  @@index([ingredientId])
}

model RecipeStep {
  id          String   @id @default(cuid())
  recipeId    String
  recipe      Recipe    @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  stepNumber  Int
  instruction String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([recipeId])
}

model Ingredient {
  id            String                 @id @default(cuid())
  name          String                 @unique
  unit          String                 // Inventory unit: kg, L, Pack, Unit
  currentStock  Float                  @default(0)
  lowStockLevel Float                  @default(10)
  cost          Float                  @default(0) // Cost per base unit
  supplier      String?
  image         String?
  
  isSemiFinished Boolean               @default(false)
  recipeId      String?                @unique
  recipe        Recipe?                @relation("IngredientRecipe", fields: [recipeId], references: [id])

  recipeItems   ProductIngredient[]
  usedInRecipes RecipeIngredient[]
  transactions  InventoryTransaction[]
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
}

model ProductIngredient {
  id               String          @id @default(cuid())
  productId        String
  product          Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  productVariantId String?
  productVariant   ProductVariant? @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
  ingredientId     String
  ingredient       Ingredient      @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  quantity         Float           // Consumption amount
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([productId])
  @@index([productVariantId])
  @@index([ingredientId])
  @@unique([productId, productVariantId, ingredientId])
}

model InventoryTransaction {
  id           String      @id @default(cuid())
  ingredientId String?
  ingredient   Ingredient? @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  type         String      // Purchase, Consumption, Wastage, Adjustment, Refund, Cancelled
  quantity     Float       // The delta change (positive or negative)
  beforeQty    Float
  afterQty     Float
  note         String?
  userId       String?
  user         User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([ingredientId])
  @@index([userId])
}

model Coupon {
  id              String   @id @default(cuid())
  code            String   @unique
  discountType    String   // Percentage, FixedAmount
  discountValue   Float
  minOrderAmount  Float?
  maxDiscount     Float?
  expiryDate      DateTime
  usageLimit      Int?
  usedCount       Int      @default(0)
  orders          Order[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Payment {
  id            String   @id @default(cuid())
  orderId       String
  order         Order    @relation(fields: [orderId], references: [id])
  amount        Float
  method        String   // Cash, Card
  status        String   // Completed, Refunded
  transactionId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([orderId])
}

model CashierSession {
  id           String    @id @default(cuid())
  userId       String
  openingTime  DateTime  @default(now())
  closingTime  DateTime?
  openingBalance Float
  closingBalance Float?
  totalRevenue Float     @default(0)
  orders       Order[]
  status       String    @default("Open") // Open, Closed
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  module    String
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  isRead    Boolean  @default(false)
  type      String   // Info, Warning, Alert
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  group     String   // System, Cafe, UI, Finance
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id])
  refreshToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
}

model OrderStatusHistory {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fromStatus  String
  toStatus    String
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  notes       String?
  createdAt   DateTime @default(now())

  @@index([orderId])
  @@index([userId])
}
